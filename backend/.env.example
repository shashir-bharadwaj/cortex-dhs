# Copy this file to .env and modify values for your environment

# Database connection (PostgreSQL with TimescaleDB extension)
DATABASE_URL=postgresql://postgres:postgres@db:5432/cortex_icu

# Secret used to sign JWT tokens
SECRET_KEY=change_this_secret

# Allowed origins for CORS (comma separated)
ALLOWED_HOSTS=*

# OTP issuer name
OTP_ISSUER=CortexICU